# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pmp_dev
DB_USER=pmp_user
DB_PASSWORD=changeme

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h

# ─── Azure AD (MS365 SSO) ─────────────────────────────────────────────────────
# ACTION REQUIRED: Complete the Azure AD App Registration before Block 2.
# See: https://portal.azure.com → Azure Active Directory → App registrations
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_CLIENT_SECRET=your-azure-app-client-secret
AZURE_REDIRECT_URI=http://localhost:4000/auth/callback

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Used to send password reset emails. Get your key at https://resend.com
RESEND_API_KEY=re_your_resend_api_key_here

# Optional: override the base URL used in password reset links.
# Defaults to CORS_ORIGIN if not set.
# FRONTEND_URL=http://localhost:5173





